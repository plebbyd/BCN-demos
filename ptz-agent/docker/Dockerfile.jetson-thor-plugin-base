# Waggle-style plugin base for NVIDIA Jetson Thor (JetPack 7+ / CUDA 13.x, SBSA arm64)
#
# Context from the legacy image you linked (waggle/plugin-base:1.1.1-ml-torch1.9):
# - Docker Hub lists separate manifests per arch (e.g. amd64 digest sha256:0614cfb4…,
#   arm64 sha256:912fa8b9…); the layer view shows a classic NVIDIA CUDA base
#   (that tag was CUDA 11.x era on amd64) plus many RUN layers for ML stack.
# - Upstream Dockerfiles: https://github.com/waggle-sensor/plugin-base-images
#   (ml/ + ml-torch/ — old arm64 path used l4t-ml + Jetson-specific torch wheels).
#
# Thor uses the unified arm64 SBSA CUDA 13 toolchain (not cuda-tegra wheels). NGC CUDA
# Ubuntu 24.04 images are the supported baseline; run with Docker's NVIDIA runtime:
#   docker run --rm -it --gpus all --runtime=nvidia \
#     -v "$PWD":/workspace -w /workspace \
#     your-registry/jetson-thor-plugin-base:local
#
# Pin the CUDA image tag to match your JetPack / driver (13.0.0 vs 13.0.2, devel vs runtime).
ARG CUDA_IMAGE=nvcr.io/nvidia/cuda:13.0.2-devel-ubuntu24.04
FROM ${CUDA_IMAGE}

LABEL description="Ubuntu 24.04 + CUDA 13 + Python ML stack + pywaggle (Waggle plugin-base style, Jetson Thor SBSA)"
LABEL maintainer="derived-from waggle-sensor/plugin-base-images patterns"
LABEL url="https://github.com/waggle-sensor/plugin-base-images"

ENV DEBIAN_FRONTEND=noninteractive
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    gnupg \
    lsb-release \
    nano \
    wget \
    python3 \
    python3-dev \
    python3-pip \
    python3-venv \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libjpeg-dev \
    zlib1g-dev \
    libpython3-dev \
    libavcodec-dev \
    libavformat-dev \
    libswscale-dev \
    # jetson-containers uses libomp on SBSA instead of OpenBLAS-heavy stacks
    libomp-dev \
    build-essential \
    cmake \
    pkg-config \
 && rm -rf /var/lib/apt/lists/*

# Ubuntu 24.04 marks system Python as PEP 668 "externally managed"; use a venv for pip installs.
RUN python3 -m venv /opt/venv \
 && /opt/venv/bin/pip install --no-cache-dir --upgrade pip setuptools wheel
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="/opt/venv/bin:${PATH}"

# Core scientific / CV stack (versions float with Ubuntu 24.04; pin in your plugin if needed)
RUN pip install --no-cache-dir \
    numpy \
    opencv-python \
    numba \
    pandas \
    scipy \
    scikit-learn \
    onnx \
    jupyterlab \
    ipython

# PyTorch: official cu130 wheels (aarch64). Adjust versions to match a tested trio from pytorch.org.
RUN pip install --no-cache-dir \
    torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cu130

# Waggle Python SDK (same as historical plugin-base images)
RUN pip install --no-cache-dir \
    "git+https://github.com/waggle-sensor/pywaggle"

# Smoke test (fails at build time if CUDA driver is not visible — comment out for CI builds)
# RUN python3 -c "import torch; print(torch.__version__, torch.cuda.is_available())"

WORKDIR /workspace
CMD ["/bin/bash"]
